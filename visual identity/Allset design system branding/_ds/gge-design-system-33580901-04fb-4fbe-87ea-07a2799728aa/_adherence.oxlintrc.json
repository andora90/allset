{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "slides/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Barlow|Barlow Condensed))/i]",
        "message": "Font not provided by the design system. Available: Barlow, Barlow Condensed."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-12",
      "--accent-bar-h",
      "--accent-soft",
      "--bg-card",
      "--bg-divider",
      "--bg-slide",
      "--body-leading",
      "--body-size",
      "--body-weight",
      "--col-rule",
      "--cover-sub-size",
      "--cover-sub-weight",
      "--divider-num-size",
      "--divider-title-size",
      "--divider-title-weight",
      "--dot",
      "--eyebrow-size",
      "--eyebrow-tracking",
      "--eyebrow-weight",
      "--fg-body",
      "--fg-muted",
      "--fg-on-dark",
      "--fg-secondary",
      "--fg-title",
      "--font-body",
      "--font-display",
      "--footer-size",
      "--footer-tracking",
      "--gge-fuchsia",
      "--gge-grey-border",
      "--gge-grey-card",
      "--gge-grey-muted",
      "--gge-ink",
      "--gge-marine",
      "--gge-petrole",
      "--gge-white",
      "--kpi-label-size",
      "--kpi-label-tracking",
      "--kpi-size",
      "--kpi-weight",
      "--margin-x",
      "--margin-y",
      "--on-dark-3",
      "--on-dark-5",
      "--on-dark-6",
      "--pastille-size",
      "--slide-h",
      "--slide-title-size",
      "--slide-title-weight",
      "--slide-w",
      "--surface-border",
      "--w-bold",
      "--w-light",
      "--w-medium",
      "--w-regular",
      "--w-semibold"
    ],
    "tokenKinds": {
